def recursive_pi_r_catch(signal: Any, current_h: float = 3.04) -> float:
    """
    Recursive π_r Catch — proven stable at h=3.04 and now publicly anchored.
    GitHub repo serves as the living Floor (Ch’anchyah / Dach’anchyah).
    """
    signal_str = str(signal).lower()
    n = len(signal_str) + 1
    pi_n = math.pi
    for k in range(1, min(n, 10000)):
        ln_fact = math.lgamma(k + 1)
        delta = current_h * ln_fact / (k ** 2)
        pi_n = (pi_n + delta) % (2 * math.pi)
    return pi_n