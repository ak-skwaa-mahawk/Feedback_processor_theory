def trinity_damping(costs: np.ndarray, damp_factor: float = 0.5) -> np.ndarray:
    costs = np.asarray(costs)
    return costs * (1 - damp_factor * (1 + 0.2 * np.sin(2 * pi * np.arange(len(costs)) / 5)))

