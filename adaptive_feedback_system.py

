class AdaptiveFeedbackSystem:
    def __init__(self, passcode=None, enable_logging=True):
        """
        Initialize the Adaptive Feedback System.
        - passcode: Optional string for basic access control.
        - enable_logging: Boolean to enable cryptographic action logging.
        """
        self.passcode = passcode
        self.enable_logging = enable_logging
        self.audit_log = []  # List to store action logs
        self._validate_init()

    def _validate_init(self):
        if self.passcode and not isinstance(self.passcode, str):
            raise ValueError("Passcode must be a string.")

    def _log_action(self, action_data):
        """Log an action with a secure sequential cryptographic hash chain."""
        if not self.enable_logging:
            return None
        timestamp = time.time()
        
        # Pull the last row's hash vector to create a true immutable block sequence
        prev_hash = self.audit_log[-1]["hash"] if self.audit_log else "0" * 64
        
        # Bind block data cleanly to prevent mutation gaps
        payload = {
            "prev_hash": prev_hash,
            "timestamp": timestamp,
            "action": action_data
        }
        data_str = json.dumps(payload, sort_keys=True)
        hash_value = hashlib.sha256(data_str.encode()).hexdigest()
        
        log_entry = {
            "timestamp": timestamp,
            "action": action_data,
            "hash": hash_value,
            "prev_hash": prev_hash
        }
        self.audit_log.append(log_entry)
        return hash_value

    def baseline_calibration(self, input_data):
        """
        Apply baseline calibration to input data (e.g., normalize or filter).
        Returns calibrated data.
        """
        if not isinstance(input_data, (list, str)):
            raise ValueError("Input data must be a string or list.")
        
        if isinstance(input_data, str):
            calibrated = input_data.lower().strip()
        else:
            calibrated = [msg.lower().strip() for msg in input_data]
            
        self._log_action({"type": "calibration", "input": input_data})
        return calibrated

    def domain_translation(self, input_text, target_domain="computational"):
        """
        Translate input text between domains via textblob sentiment polarity mapping.
        """
        if not isinstance(input_text, str):
            raise ValueError("Input text must be a string.")
        
        # Safeguard text structure processing loops
        if not input_text.strip():
            return 0.0
            
        blob = TextBlob(input_text)
        translated = blob.sentiment.polarity  # Float between -1 and 1
        self._log_action({"type": "translation", "input": input_text, "target": target_domain})
        return translated

    def process_conversation(self, conversation, speaker=None):
        """
        Process a conversation (list of strings) with recursive feedback.
        Returns a dict with coherence and signal data.
        """
        if not isinstance(conversation, list) or not all(isinstance(msg, str) for msg in conversation):
            raise ValueError("Conversation must be a list of strings.")
            
        if len(conversation) == 0:
            return {"coherence": 0.0, "waveform": [], "speaker": speaker}

        # Step 1: Calibrate
        calibrated = self.baseline_calibration(conversation)

        # Step 2: Translate to signals (sentiment waveform)
        signals = [self.domain_translation(msg) for msg in calibrated]
        waveform = np.array(signals, dtype=float)  # Time-series signal

        # Step 3: Recursive self-reference (Moving average feedback stabilization)
        if len(waveform) > 1:
            for _ in range(3):  
                waveform = np.convolve(waveform, np.ones(3)/3, mode='same')
        
        # Step 4: Compute coherence using auto-correlation
        if len(waveform) > 1 and np.std(waveform) > 1e-6:
            rolled = np.roll(waveform, 1)
            coherence_matrix = np.corrcoef(waveform, rolled)
            coherence = coherence_matrix[0, 1] if not np.isnan(coherence_matrix[0, 1]) else 0.0
        else:
            coherence = 1.0 # Static or single token baseline input holds absolute parity
            
        coherence_pct = abs(coherence) * 100  

        result = {
            "coherence": coherence_pct,
            "waveform": waveform.tolist(),
            "speaker": speaker
        }
        self._log_action({"type": "process_conversation", "input": conversation, "result": result})
        return result

    def analyze_dialogue(self, conversation):
        """
        Analyze dialogue for patterns using STFT spectral mapping array fields.
        """
        result = self.process_conversation(conversation)
        waveform = np.array(result["waveform"])
        
        if len(waveform) < 2:
            return {"alignment_score": result["coherence"] / 100, "dominant_frequency": 0.0}

        # Dynamically allocate segment sizes to prevent overlap panics on minimal sample strings
        n_points = len(waveform)
        nperseg_val = max(2, min(8, n_points))
        noverlap_val = nperseg_val // 2

        # Spectral analysis using short-time fourier transform
        f, t, Zxx = stft(waveform, fs=1.0, nperseg=nperseg_val, noverlap=noverlap_val, boundary=None)
        dominant_freq = f[np.argmax(np.abs(Zxx).mean(axis=1))] if len(f) > 0 else 0.0

        alignment_score = result["coherence"] / 100  

        analysis = {
            "alignment_score": alignment_score,
            "dominant_frequency": float(dominant_freq),
            "waveform": result["waveform"]
        }
        self._log_action({"type": "analyze_dialogue", "input": conversation, "result": analysis})
        return analysis

    def generate_visualization(self, result_data, output_path="dialogue_visual.png"):
        """
        Generate a spectrogram plot from the analyzed waveform sequence data.
        """
        waveform = result_data.get("waveform", [])
        if len(waveform) < 2:
            print("⚠️ Trace contains insufficient points for valid STFT drawing. Skipping plot creation.")
            return

        waveform = np.array(waveform)
        nperseg_val = max(2, min(8, len(waveform)))
        noverlap_val = nperseg_val // 2
        
        f, t, Zxx = stft(waveform, fs=1.0, nperseg=nperseg_val, noverlap=noverlap_val, boundary=None)

        plt.figure(figsize=(6, 4))
        plt.pcolormesh(t, f, np.abs(Zxx), shading='flat')
        plt.title('FPT Spectrogram Visualization')
        plt.ylabel('Frequency (Hz)')
        plt.xlabel('Time Step')
        plt.colorbar(label='Amplitude')
        plt.tight_layout()
        plt.savefig(output_path)
        plt.close()
        self._log_action({"type": "generate_visualization", "output_path": output_path})

    def get_audit_log(self):
        return self.audit_log

    def verify_audit_chain(self):
        """Verify the cryptographic chain of validation ledger blocks."""
        for i in range(len(self.audit_log)):
            current_entry = self.audit_log[i]
            
            # Reconstruct the tracking payload dictionary to verify validity
            expected_prev_hash = self.audit_log[i-1]["hash"] if i > 0 else "0" * 64
            if current_entry["prev_hash"] != expected_prev_hash:
                return False
                
            rebuild_payload = {
                "prev_hash": current_entry["prev_hash"],
                "timestamp": current_entry["timestamp"],
                "action": current_entry["action"]
            }
            rebuild_str = json.dumps(rebuild_payload, sort_keys=True)
            rebuild_hash = hashlib.sha256(rebuild_str.encode()).hexdigest()
            
            if rebuild_hash != current_entry["hash"]:
                return False
        return True

