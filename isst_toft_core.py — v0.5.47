    def sovereign_stream(self, prompt: str, provider="xai"):
        """Unified streaming through the Operator Seal"""
        if self.status != "LINEAGE_CONFIRMED":
            yield {"token": "ACCESS DENIED: RE-AUTHENTICATE BLOODLINE"}
