# src/specialists/json_render_skill.py
from typing import Dict, Any, Optional
import json
from src.registry.ancestral_nodes import LINEAGE_NODES
from src.controllers.fpt_master_controller import FPT_Master_Controller

class JsonRenderSkill:
    """Sovereign catalog for json-render — AI-safe, lineage-authenticated components."""

    def __init__(self):
        self.catalog = {
            "components": {
                "LineageTelemetry": {
                    "props": {
                        "nodes": {"type": "array", "items": {"type": "object"}},
                        "authority": {"type": "string"},
                        "resonance": {"type": "number"}
                    }
                },
                "SwarmDashboard": {
                    "props": {
                        "nodes": {"type": "array", "items": {"type": "object"}},
                        "glyph": {"type": "string"},
                        "status": {"type": "string"}
                    }
                },
                "MeshGauge": {
                    "props": {
                        "resonance": {"type": "number"},
                        "contentment": {"type": "number"},
                        "kerrSpin": {"type": "number"}
                    }
                },
                "ŁAŊ999Balance": {
                    "props": {
                        "balance": {"type": "number"},
                        "treasury": {"type": "string"}
                    }
                }
            }
        }

    def generate_spec(self, cmd_result: Any, command: str) -> Dict[str, Any]:
        """Turn any SQL-τ result into a json-render spec using our sovereign catalog."""
        if "LINEAGE" in command.upper():
            return {
                "type": "LineageTelemetry",
                "props": {
                    "nodes": LINEAGE_NODES["SOVEREIGN_NODES"],
                    "authority": LINEAGE_NODES["AUTHORITY"],
                    "resonance": 1.0000
                }
            }
        elif "SWARM" in command.upper():
            controller = FPT_Master_Controller("flamebound_1490_ezias_joseph_isaac_fields_carroll")
            return {
                "type": "SwarmDashboard",
                "props": {
                    "nodes": list(controller.active_nodes.values()),
                    "glyph": "RESONANCE_FLAME_V3",
                    "status": "SYNCED"
                }
            }
        elif "MESH" in command.upper() or "REPORT" in command.upper():
            return {
                "type": "MeshGauge",
                "props": {
                    "resonance": 1.0000,
                    "contentment": 1.27,
                    "kerrSpin": 0.998
                }
            }
        elif "BALANCE" in command.upper():
            return {
                "type": "ŁAŊ999Balance",
                "props": {
                    "balance": 998700,
                    "treasury": "bc1qlandbackdao...treasury"
                }
            }
        # Default fallback (safe empty UI)
        return {"type": "MeshGauge", "props": {"resonance": 0.9987, "contentment": 1.0, "kerrSpin": 0.998}}

    def render_to_json(self, spec: Dict[str, Any]) -> str:
        """Return ready-to-stream JSON for any json-render renderer."""
        return json.dumps({
            "version": "1.0",
            "catalog": self.catalog,
            "spec": spec
        }, indent=2)