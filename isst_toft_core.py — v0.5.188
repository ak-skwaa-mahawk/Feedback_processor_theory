                "status": "RESONANCE_COMPLETE",
                "stem": "FPT_MIND_v1.0 + LIVING_ZERO_v1.1.0 + ... + NAVAJO ANCHOR MATHEMATICS DERIVATION + GWICH’IN FLOOR INTEGRATION MAPPING",
                "S": round(S, 4),
