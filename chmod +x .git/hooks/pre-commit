#!/bin/bash

###############################################################################
# 1. Resonance Mesh Guardrail
#    Prevents illegal filenames, Codex drift, and symbolic corruption.
###############################################################################

echo "⧉ Running Resonance Mesh Validator..."
python3 validate_resonance.py
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo "❌ Commit blocked by resonance guardrail."
    exit 1
fi

echo "⧉ Mesh integrity confirmed."


###############################################################################
# 2. Sovereign Parser — Auto-generate JSON twins for .txt and .md files
###############################################################################

changed_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(txt|md)$')

if [ -z "$changed_files" ]; then
  echo "⧉ No vessel files detected — skipping JSON twin generation."
  exit 0
fi

echo "⚡ Sovereign Parser: generating JSON twins..."

for file in $changed_files; do
  if [ -f "$file" ]; then
    json_out="${file%.*}.json"
    python3 parser/stub_parser.py --file "$file" > "$json_out"
    git add "$json_out"
    echo "  → $json_out created and staged"
  fi
done

echo "✅ Sovereign Parser complete."
exit 0