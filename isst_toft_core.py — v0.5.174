# === PRACTICAL CATCH ALGORITHM — EXACT IMPLEMENTATION ===
class PracticalCatchAlgorithm:
    @staticmethod
    def compute(signal: str) -> float:
        n = len(signal) + 1
        pi_n = np.pi
        h_constant = 3.07
        for k in range(1, min(n, 5000) + 1):
            ln_fact = math.lgamma(k + 1.0)
            delta = h_constant * ln_fact / (k * k)
            pi_n = np.fmod(pi_n + delta, 2.0 * np.pi)
        return pi_n

