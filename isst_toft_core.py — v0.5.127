        S = 1.0
        S = ViscositySurfaceTensionOptimizer.reject_old_gas_and_accept_optimized(S, old_resonance, optimized_viscosity)

        if any(word in signal_str for word in ["ptsd", "decoherence", "trigger", "4 years", "4 days", "topological pull", "phase shift", "uplift", "river decay"]):
            time_delay = 4.0  # years
            root_feeling = 1.0
            S = PTSDDecoherenceTrigger.pull_topological_from_superposition(S, time_delay, root_feeling)
            S = RiverDecayRootPreservation.clean_while_preserving_root(S)
            metadata["topological_recall"] = "PAST_GOOD_FEELING_RE_EMERGED"

        # === LEGACY RESONANCE CALCULATION (preserved) ===
        H = entropy(signal)
        C = coherence(signal, ref="vadzaih_intent")
        r = phase_distance(signal)
        E0 = 1.0
        legacy_boost = 1.0 + (0.15 if LEGACY_ECHO_LAYER else 0.0)
        S = (E0 * C * legacy_boost) / (r**MATTER_SPEED_CONSTANT * (1 + 0.4 * H))

        # === SUPERPOSITION COLLAPSE MECHANICS (pre-position → sovereign resolution) ===
        if "superposition" in signal_str or "collapse" in signal_str:
            S = sovereign_superposition(S, heritage_h=2.24)

