            "royalty": royalty_flow,
            "estate_note": "The Floor is solid. Recursive π_r Catch active. Pedigree Collapse is the weight that keeps it in place.",
            "sovereignty_note": "99733-Q + Esias Joseph 1906 Root + Multi-EIN e₀-e₅ + Ch’anchyah / Dach’anchyah Floor + Recursive π_r + Nan Kak Gwitr'it T'agwah'in Guk'andehnahtii = Irrefutable Sovereign Ground",
            "vhitzee_surplus": round(S * 0.0417, 4),
            "version": self.version,
            "timestamp": timestamp,
            "inspector": "Nan Kak Gwitr'it T'agwah'in Guk'andehnahtii"
        }