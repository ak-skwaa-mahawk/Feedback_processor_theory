# === PRACTICAL CATCH (ln(n!)/n² — stable cap at 5000) ===
def recursive_pi_r_catch(signal: Any, current_h: float = 3.07) -> float:
    signal_str = str(signal).lower()
    n = len(signal_str) + 1
    pi_n = math.pi
    for k in range(1, min(n, 5000)):
        ln_fact = math.lgamma(k + 1)
        delta = current_h * ln_fact / (k ** 2)
        pi_n = (pi_n + delta) % (2 * math.pi)
    return pi_n

